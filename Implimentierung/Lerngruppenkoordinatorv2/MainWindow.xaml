<Window x:Class="LerngruppekoordinatorAufgabe2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LerngruppekoordinatorAufgabe2"
        mc:Ignorable="d"
        Title="LerngruppenKoordinator" Height="600" Width="1000" MinWidth="600" MinHeight="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Margin="10,10,0,0" 
                   VerticalAlignment="Top" 
                   HorizontalAlignment="Left">Name</TextBlock>
        <TextBlock x:Name="txtSuchName" 
                 Grid.ColumnSpan="2" 
                 Margin="10,35,500,0" 
                 Height="25" 
                 VerticalAlignment="Top" 
                 Text="{Binding Nutzer.Name}"/>
        <Button Grid.Column="0" 
                Margin="10,70,0,0" 
                Width="150" 
                Height="25" 
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Click="GruppeSuchen">Lerngruppe Suchen</Button>
        <Button Grid.Column="0" 
                Margin="200,70,0,0" 
                Width="150" 
                Height="25" 
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Click="BenutzerAnmelden">Benutzer ändern</Button>
        <Button Grid.Column="1" 
                Margin="0,70,10,0" 
                Width="120" 
                Height="25" 
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Click="Einstellungen">Einstellungen</Button>
        <TextBlock Grid.Row="1" 
                   Grid.ColumnSpan="2" 
                   Margin="10,5,10,0" 
                   FontWeight="Bold"
                   VerticalAlignment="Top">Verfügbare Lerngruppen:</TextBlock>
        <ListView x:Name="lvVerfuegbareGruppen" 
                  Grid.Row="1"
                  Grid.ColumnSpan="2" 
                  Margin="10,21,10,19"
                  ItemsSource="{Binding VerfuegbareGruppen}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="120" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Fach" Width="120" DisplayMemberBinding="{Binding Fach}"/>
                    <GridViewColumn Header="Raum" Width="70" DisplayMemberBinding="{Binding Raum}"/>
                    <GridViewColumn Header="PLZ" Width="70" DisplayMemberBinding="{Binding Plz}"/>
                    <GridViewColumn Header="Adresse" Width="150" DisplayMemberBinding="{Binding Adresse}"/>
                    <GridViewColumn Header="Datum/Uhrzeit" Width="130" DisplayMemberBinding="{Binding DatumUhrzeit, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                    <GridViewColumn Header="Beitreten" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✓" 
                            Width="60" 
                            Height="25"
                            Click="Beigetreten"
                            Tag="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="PDF" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Download" 
                                Click="PdfAnzeigenLerngruppe"
                                Width="75" Height="25"
                                Tag="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Button Grid.Row="3" 
                Grid.Column="0"
                Margin="10,100,10,0" 
                Width="150" 
                Height="30" 
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Click="GruppeErstellen">Gruppe Erstellen</Button>
        
        <TextBlock Grid.Row="2" 
                   Grid.ColumnSpan="2" 
                   Margin="10,5,10,0" 
                   FontWeight="Bold"
                   VerticalAlignment="Top">Meine Lerngruppen:</TextBlock>

        <ListView x:Name="lvMeineGruppen"
                  Grid.Row="2" 
                  Grid.ColumnSpan="2"
                  Grid.RowSpan="2"
                  Margin="10,30,10,100"
                  ItemsSource="{Binding MeineGruppen}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="120" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Fach" Width="120" DisplayMemberBinding="{Binding Fach}"/>
                    <GridViewColumn Header="Raum" Width="70" DisplayMemberBinding="{Binding Raum}"/>
                    <GridViewColumn Header="PLZ" Width="70" DisplayMemberBinding="{Binding Plz}"/>
                    <GridViewColumn Header="Adresse" Width="150" DisplayMemberBinding="{Binding Adresse}"/>
                    <GridViewColumn Header="Datum/Uhrzeit" Width="130" DisplayMemberBinding="{Binding DatumUhrzeit, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                    <GridViewColumn Header="Verlassen?" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✓" Width="60" Height="25" Click="Verlassen" Tag="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="PDF Upload" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Upload" 
                                Width="75" Height="25"
                                Click="PdfUploadTermin"
                                Tag="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="PDF Anzeigen" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="PDF" 
                                Width="75" Height="25"
                                Click="PdfAnzeigenTermin"
                                Tag="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
