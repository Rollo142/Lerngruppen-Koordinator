<Window x:Class="LerngruppekoordinatorAufgabe2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LerngruppekoordinatorAufgabe2"
        mc:Ignorable="d"
        Title="LerngruppenKoordinator" Height="600" Width="650" MinWidth="600" MinHeight="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Margin="10,10,0,0" 
                   VerticalAlignment="Top" 
                   HorizontalAlignment="Left">Name</TextBlock>
        <TextBox x:Name="txtSuchName" 
                 Grid.ColumnSpan="2" 
                 Margin="10,35,10,0" 
                 Height="25" 
                 VerticalAlignment="Top"/>
        <Button Grid.Column="0" 
                Margin="10,70,0,0" 
                Width="150" 
                Height="25" 
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Click="LerngruppeSuchen">Lerngruppe Suchen</Button>
        <Button Grid.Column="1" 
                Margin="0,70,10,0" 
                Width="120" 
                Height="25" 
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Click="Einstellungen">Einstellungen</Button>
        <TextBlock Grid.Row="1" 
                   Grid.ColumnSpan="2" 
                   Margin="10,5,10,0" 
                   FontWeight="Bold"
                   VerticalAlignment="Top">Verfügbare Lerngruppen:</TextBlock>
        <ListView x:Name="lvVerfuegbareGruppen" 
                  Grid.Row="1"
                  Grid.ColumnSpan="2" 
                  Margin="10,21,10,19"
                  ItemsSource="{Binding}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="120" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Fach" Width="120" DisplayMemberBinding="{Binding Fach}"/>
                    <GridViewColumn Header="Raum" Width="70" DisplayMemberBinding="{Binding Raum}"/>
                    <GridViewColumn Header="PLZ" Width="70" DisplayMemberBinding="{Binding Plz}"/>
                    <GridViewColumn Header="Adresse" Width="150" DisplayMemberBinding="{Binding Adresse}"/>
                    <GridViewColumn Header="Beitreten" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✓" 
                            Width="60" 
                            Height="25"
                            
                            Tag="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        
        <Button Grid.Row="2" 
                Grid.Column="0"
                Margin="10,10,10,0" 
                Width="150" 
                Height="30" 
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Click="GruppeErstellen">Gruppe Erstellen</Button>
        <TextBox x:Name="txtGruppenDetails"
                 Grid.Row="2"
                 Grid.ColumnSpan="2" 
                 Margin="10,50,10,10"
                 TextWrapping="Wrap"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto">Wähle eine Gruppe aus oder erstelle eine neue</TextBox>
        <TextBlock Grid.Row="3" 
                   Grid.ColumnSpan="2" 
                   Margin="10,5,10,0" 
                   FontWeight="Bold"
                   VerticalAlignment="Top">Meine Lerngruppen:</TextBlock>

        <ListView x:Name="lvMeineGruppen"
                  Grid.Row="3" 
                  Grid.ColumnSpan="2" 
                  Margin="10,30,10,10"
                  ItemsSource="{Binding MeineGruppen}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="120" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Fach" Width="120" DisplayMemberBinding="{Binding Fach}"/>
                    <GridViewColumn Header="Raum" Width="70" DisplayMemberBinding="{Binding Raum}"/>
                    <GridViewColumn Header="PLZ" Width="70" DisplayMemberBinding="{Binding Plz}"/>
                    <GridViewColumn Header="Adresse" Width="150" DisplayMemberBinding="{Binding Adresse}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
