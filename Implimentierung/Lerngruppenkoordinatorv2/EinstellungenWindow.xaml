<Window x:Class="LerngruppekoordinatorAufgabe2.EinstellungenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="20">
        <Border x:Name="statusBorder" 
                DockPanel.Dock="Bottom"
                CornerRadius="4" 
                BorderThickness="1" 
                Padding="10" 
                Visibility="Collapsed">
            <TextBlock x:Name="txtStatus" TextWrapping="Wrap"/>
        </Border>
        <StackPanel>
            <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,15">Datenbankverbindung</TextBlock>
            <Button Width="150" Height="30" HorizontalAlignment="Left" 
                    Margin="0,0,0,10" Click="VerbindungTesten">Verbindung testen</Button>
            <Button Width="150" Height="30" HorizontalAlignment="Left" 
                    Click="DatenZuruecksetzen">Beispieldaten einfügen</Button>
        </StackPanel>

    </DockPanel>
</Window>