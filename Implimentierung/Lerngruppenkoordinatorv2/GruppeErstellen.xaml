<Window x:Class="LerngruppekoordinatorAufgabe2.GruppeErstellenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gruppe Erstellen" Height="350" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" VerticalAlignment="Center">Name:</TextBlock>
        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="0,5,0,5"/>
        <TextBlock Grid.Row="1" VerticalAlignment="Center">Fach:</TextBlock>
        <TextBox x:Name="txtFach" Grid.Row="1" Grid.Column="1" Margin="0,5,0,5"/>
        <TextBlock Grid.Row="2" VerticalAlignment="Center">Raum:</TextBlock>
        <TextBox x:Name="txtRaum" Grid.Row="2" Grid.Column="1" Margin="0,5,0,5"/>

        <TextBlock Grid.Row="3" VerticalAlignment="Center">Adresse:</TextBlock>
        <TextBox x:Name="txtAdresse" Grid.Row="3" Grid.Column="1" Margin="0,5,0,5"/>
        <TextBlock Grid.Row="4" VerticalAlignment="Center">PLZ:</TextBlock>
        <TextBox x:Name="txtPlz" Grid.Row="4" Grid.Column="1" Margin="0,5,0,5"/>
        <TextBlock Grid.Row="5" VerticalAlignment="Center">Datum/Uhrzeit:</TextBlock>
        <DatePicker x:Name="dpDatum" Grid.Row="5" Grid.Column="1" Margin="0,5,0,5"/>
        <Button Grid.Row="6" Grid.Column="1"
                Width="100" Height="30"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                Click="Erstellen">Erstellen</Button>
    </Grid>
</Window>