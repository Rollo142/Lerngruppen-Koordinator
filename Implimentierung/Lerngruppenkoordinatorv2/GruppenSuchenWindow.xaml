<Window x:Class="LerngruppekoordinatorAufgabe2.GruppeSuchenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lerngruppe Suchen" Height="400" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">Suchen:</TextBlock>
            <TextBox x:Name="txtSuche" Width="200" Height="25" 
                     VerticalContentAlignment="Center"
                     TextChanged="txtSuche_TextChanged"/>
            <TextBlock VerticalAlignment="Center" Margin="10,0,10,0">Fach:</TextBlock>
            <TextBox x:Name="txtFachSuche" Width="150" Height="25"
                     VerticalContentAlignment="Center"
                     TextChanged="txtSuche_TextChanged"/>
        </StackPanel>

        <ListView x:Name="lvSucheGruppen"
                  Grid.Row="1"
                  ItemsSource="{Binding GefilterteGruppen}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name"    Width="120" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Fach"    Width="120" DisplayMemberBinding="{Binding Fach}"/>
                    <GridViewColumn Header="Raum"    Width="60"  DisplayMemberBinding="{Binding Raum}"/>
                    <GridViewColumn Header="PLZ"     Width="60"  DisplayMemberBinding="{Binding Plz}"/>
                    <GridViewColumn Header="Adresse" Width="130" DisplayMemberBinding="{Binding Adresse}"/>
                    <GridViewColumn Header="Datum"   Width="120" DisplayMemberBinding="{Binding DatumUhrzeit, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                    <GridViewColumn Header="Beitreten" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✓" Width="60" Height="25"
                                Click="Beitreten"
                                Tag="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>