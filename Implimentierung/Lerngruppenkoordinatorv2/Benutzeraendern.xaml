<Window x:Class="LerngruppekoordinatorAufgabe2.BenutzerAendernWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Benutzer ändern" Height="800" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" VerticalAlignment="Center">Name:</TextBlock>
        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="0,5,0,5"/>

        <TextBlock Grid.Row="1" VerticalAlignment="Center">Adresse:</TextBlock>
        <TextBox x:Name="txtAdresse" Grid.Row="1" Grid.Column="1" Margin="0,5,0,5"/>

        <TextBlock Grid.Row="2" VerticalAlignment="Center">PLZ:</TextBlock>
        <TextBox x:Name="txtPlz" Grid.Row="2" Grid.Column="1" Margin="0,5,0,5"/>

        <TextBlock Grid.Row="3" VerticalAlignment="Center">Studiengang:</TextBlock>
        <TextBox x:Name="txtStudiengang" Grid.Row="3" Grid.Column="1" Margin="0,5,0,5"/>

        <TextBlock Grid.Row="4" VerticalAlignment="Center">Fachsemester:</TextBlock>
        <TextBox x:Name="txtFachsemester" Grid.Row="4" Grid.Column="1" Margin="0,5,0,5"/>

        <Button Grid.Row="6" Grid.Column="1" 
                Width="100" Height="30"
                HorizontalAlignment="Right"
                Margin="0,15,0,1120"
                Click="Speichern">Speichern</Button>

        <ListView x:Name="lvBenutzer" 
          Grid.Row="6"
          Grid.ColumnSpan="2" 
          Margin="10,150,10,1"
          ItemsSource="{Binding Benutzer}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name"         Width="120" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Adresse"      Width="150" DisplayMemberBinding="{Binding Adresse}"/>
                    <GridViewColumn Header="PLZ"          Width="70"  DisplayMemberBinding="{Binding Plz}"/>
                    <GridViewColumn Header="Studiengang"  Width="120" DisplayMemberBinding="{Binding Studiengang}"/>
                    <GridViewColumn Header="Fachsemester" Width="90"  DisplayMemberBinding="{Binding Fachsemester}"/>
                    <GridViewColumn Header="Auswählen" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✓" 
                                Width="60" 
                                Height="25"
                                Click="BenutzerAuswaehlen"
                                Tag="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>